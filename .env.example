# Environment Configuration for StackScope++
# Copy this file to .env and update values as needed

# ==================== Gemini AI API ====================
# Required for natural language to expression conversion
GEMINI_API_KEY=your_gemini_api_key_here

# ==================== Logging Configuration ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
STACKSCOPE_LOG_LEVEL=INFO

# ==================== Streamlit Configuration ====================
# Streamlit server settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
STREAMLIT_CLIENT_TOOLBAR_MODE=auto

# ==================== Performance Settings ====================
# Timeout for expression evaluation (seconds)
STACKSCOPE_TIMEOUT=10

# Maximum expression length
STACKSCOPE_MAX_EXPR_LENGTH=1000

# ==================== Visualization ====================
# Enable JSON logging for visualization
STACKSCOPE_ENABLE_LOGGING=true

# Visualization output directory
STACKSCOPE_VIZ_DIR=./visualize
